# CargoGent reverse proxy
# Use http://localhost (not https). From another device on the same network use http://<this-machine-ip>

(routes) {
	# AWBTrackers (tracking API)
	handle /track/* {
		reverse_proxy awbtrackers:8000
	}
	handle /health {
		reverse_proxy awbtrackers:8000
	}

	# Backend API
	handle /api/* {
		reverse_proxy backend:3000
	}

	# n8n
	handle /n8n/* {
		reverse_proxy n8n:5678
	}

	# Frontend SPA
	handle /assets/* {
		reverse_proxy frontend:8080
	}
	handle /* {
		reverse_proxy frontend:8080
	}
}

# Automatically serve HTTPS dynamically for localhost
localhost {
	# Use Caddy's internal CA to issue a locally-trusted cert for development
	tls internal
	import routes
}

# Fallback for network IP access via HTTP
:80 {
	import routes
}
