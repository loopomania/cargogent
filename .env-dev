# CargoGent Development Environment
# ----------------------------------
# This file is used for local docker-compose and npm run dev.

# First admin (backend login). Required for /api/auth/login.
ADMIN_EMAIL=alon@cargogent.com
ADMIN_PASSWORD_HASH='$2b$10$IL1Op5lXo8mhADzv7PeeVeRegM.Do58kHi2Xq4xBtNgOtoi1G4eqK'

# JWT secret for login token 
JWT_SECRET=dev-secret-change-in-prod

# HIGH-01: Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost,http://localhost:5173,http://localhost:3000

# HIGH-02: Canonical app URL used in password-reset / invite email links
APP_URL=http://localhost

# AWBTrackers: residential proxy for "hard" airlines (El Al, Delta, PAL)
PROXY_URL=http://fGFXboRq6pj4lcoe:VPawjBxwQQiC99Wy@geo.iproyal.com:12321

# MED-01: n8n Caddy basicauth credentials
N8N_ADMIN_USER=admin
N8N_ADMIN_HASH='$2a$14$01ySKAK2iwEpWz0Ie5gwUu7jCz6HLfq0fH43hic.bs1KCcbAdALWa'

# Database URL pointing to local postgres container
DATABASE_URL=postgresql://cargogent:dev@localhost:5432/cargogent

# For docker-compose inner routing (if backend needs to talk to neon locally, change this)
# AWBTrackers runs locally on port 8000
AWBTRACKERS_URL=http://localhost:8000

# n8n webhook — backend POSTs to here for invite and password-reset emails
N8N_INVITE_WEBHOOK_URL=http://localhost:5678/webhook/user-email

# SMTP fallback
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@cargogent.com
SMTP_PASS=REPLACE_WITH_APP_PASSWORD
SMTP_FROM='CargoGent <noreply@cargogent.com>'
