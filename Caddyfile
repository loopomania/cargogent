# CargoGent reverse proxy
{
	default_sni 168.119.228.149
}

(security_headers) {
	header {
		# Prevent clickjacking
		X-Frame-Options "DENY"
		# Prevent MIME sniffing
		X-Content-Type-Options "nosniff"
		# Enforce HTTPS for one year (preload-ready)
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		# Restrict referrer
		Referrer-Policy "strict-origin-when-cross-origin"
		# Minimal permissions policy
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		# Content-Security-Policy — allow same-origin + CDN fonts
		Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self' wss: ws:; frame-ancestors 'none';"
		# Remove server fingerprinting
		-Server
	}
}

(routes) {
	import security_headers

	# Backend API — all tracking goes through here (auth enforced by backend)
	handle /api/* {
		reverse_proxy backend:3000
	}

	# AWBTrackers health check only — no direct track/* exposure
	handle /health {
		reverse_proxy awbtrackers:8000
	}



	# Frontend SPA
	handle /assets/* {
		reverse_proxy frontend:8080
	}
	handle /* {
		reverse_proxy frontend:8080
	}
}

# Serve HTTPS for localhost in dev (internal CA)
localhost {
	tls internal
	import routes
}

# Production: Auto-HTTPS managed by Let's Encrypt
cargogent.com, www.cargogent.com {
	import routes
}

# Production Explicit IP Fallback (HTTP only)
http://168.119.228.149 {
	import routes
}

# Native n8n strict-port proxy with Let's Encrypt
cargogent.com:8433, www.cargogent.com:8433 {
	reverse_proxy n8n:5678
}
