{
  "name": "Email Ingestion Workflow",
  "nodes": [
    {
      "parameters": {
        "postProcessAction": "nothing",
        "format": "resolved",
        "options": {
          "allowUnauthorizedCerts": true,
          "customEmailConfig": "[\"UNSEEN\"]"
        }
      },
      "name": "IMAP Email",
      "type": "n8n-nodes-base.emailReadImap",
      "typeVersion": 2,
      "position": [
        180,
        240
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://backend:3000/api/ingest/webhook",
        "sendBody": true,
        "contentType": "multipart-form-data",
        "bodyParameters": {
          "parameters": [
            {
              "name": "fromEmail",
              "value": "={{ $json.from.value[0].address }}"
            },
            {
              "name": "subject",
              "value": "={{ $json.subject }}"
            },
            {
              "parameterType": "formBinaryData",
              "name": "file",
              "inputDataFieldName": "attachment_0"
            }
          ]
        },
        "options": {}
      },
      "name": "Send API Request to Backend",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.1,
      "position": [
        480,
        240
      ]
    }
  ],
  "pinData": {},
  "connections": {
    "IMAP Email": {
      "main": [
        [
          {
            "node": "Send API Request to Backend",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "active": false,
  "settings": {},
  "versionId": "bc115b97-75cc-48a5-abdd-9bba972bbffc",
  "id": "email-workflow-n8n"
}
