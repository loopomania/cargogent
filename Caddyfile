# CargoGent reverse proxy

(security_headers) {
	header {
		# Prevent clickjacking
		X-Frame-Options "DENY"
		# Prevent MIME sniffing
		X-Content-Type-Options "nosniff"
		# Enforce HTTPS for one year (preload-ready)
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		# Restrict referrer
		Referrer-Policy "strict-origin-when-cross-origin"
		# Minimal permissions policy
		Permissions-Policy "camera=(), microphone=(), geolocation=()"
		# Content-Security-Policy — allow same-origin + CDN fonts
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:; connect-src 'self'; frame-ancestors 'none';"
		# Remove server fingerprinting
		-Server
	}
}

(routes) {
	import security_headers

	# Backend API — all tracking goes through here (auth enforced by backend)
	handle /api/* {
		reverse_proxy backend:3000
	}

	# AWBTrackers health check only — no direct track/* exposure
	handle /health {
		reverse_proxy awbtrackers:8000
	}

	# n8n — MED-01: protected by basicauth; credentials injected from env vars.
	handle /n8n/* {
		basicauth {
			{env.N8N_ADMIN_USER} {env.N8N_ADMIN_HASH}
		}
		reverse_proxy n8n:5678
	}

	# Frontend SPA
	handle /assets/* {
		reverse_proxy frontend:8080
	}
	handle /* {
		reverse_proxy frontend:8080
	}
}

# Serve HTTPS for localhost in dev (internal CA)
localhost {
	tls internal
	import routes
}

# Production: HTTP on :80 — Caddy auto-upgrades to HTTPS when a domain is used
:80 {
	import routes
}
